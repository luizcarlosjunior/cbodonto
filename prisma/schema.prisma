// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  photoUrl  String?
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

model Dentist {
  id        String   @id @default(cuid())
  name      String
  title     String
  specialty String?  @db.Text
  cro       String
  bio       String?  @db.Text
  photoUrl  String?
  email     String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weeklySchedule   WeeklySchedule[]
  unavailableDates UnavailableDate[]
  appointments     Appointment[]
}

model WeeklySchedule {
  id        String   @id @default(cuid())
  dentistId String
  dentist   Dentist  @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  startTime String
  endTime   String
  slots     String?  // comma-separated selected slot times, e.g. "08:00,08:30,09:00"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dentistId, dayOfWeek])
}

model UnavailableDate {
  id        String   @id @default(cuid())
  dentistId String
  dentist   Dentist  @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  startTime String?
  endTime   String?
  reason    String?
  createdAt DateTime @default(now())
}

model Patient {
  id          String    @id @default(cuid())
  name        String
  email       String?   @unique
  phone       String
  birthDate   DateTime? @db.Date
  cpf         String?   @unique
  photoUrl    String?
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  appointments Appointment[]
}

model Appointment {
  id        String   @id @default(cuid())
  dentistId String
  dentist   Dentist  @relation(fields: [dentistId], references: [id])
  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id])

  guestName  String?
  guestEmail String?
  guestPhone String?

  date      DateTime          @db.Date
  startTime String
  endTime   String
  service   String
  status    AppointmentStatus @default(PENDING)
  notes     String?           @db.Text
  source    AppointmentSource @default(WEBSITE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentSource {
  WEBSITE
  WHATSAPP
  PHONE
  ADMIN
}

model Testimonial {
  id          String   @id @default(cuid())
  patientName String
  text        String   @db.Text
  rating      Int      @default(5)
  source      String   @default("Google")
  photoUrl    String?
  approved    Boolean  @default(false)
  rejected    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          String         @id @default(cuid())
  title       String
  shortDesc   String         @db.Text
  longDesc    String         @db.Text
  imageUrl    String?
  active      Boolean        @default(true)
  position    Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  images      ServiceImage[]
}

model ServiceImage {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  imageUrl  String
  position  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  seoTitle    String?
  seoDesc     String?  @db.Text
  seoTags     String?  @db.Text
  content     String?  @db.LongText
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id                   String   @id @default(cuid())
  whatsappNumber       String   @default("5541997234253")
  address              String?  // Deprecated in favor of addressLine1/2
  addressLine1         String?
  addressLine2         String?
  cnpj                 String?
  legalName            String?  // Razão Social
  tradeName            String?  // Nome Fantasia
  footerText           String?  @db.Text
  customerServiceEmail String?
  openHours            String
  instagramUrl         String?
  facebookUrl          String?
  updatedAt            DateTime @updatedAt
}
