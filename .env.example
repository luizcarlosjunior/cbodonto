NEXT_PUBLIC_APP_TITLE="título do projeto"
NEXT_PUBLIC_APP_DESCRIPTION="descrição do projeto"
NEXT_PUBLIC_APP_KEYWORDS="tag1, tag2"
NODE_ENV="development"
PORT=3000
NEXT_PUBLIC_SITE_URL="http://localhost:$PORT"
NEXT_PUBLIC_API_URL="http://localhost:$PORT/api"
NEXT_PUBLIC_TOKEN_API="gere com: openssl rand -base64 32"

#ARQUIVOS
BASE_PATH="./public/"

#EMAIL/SMTP
MAIL_DRIVER="smtp"
MAIL_HOST="smtp.sendgrid.net"
MAIL_PORT="587"
MAIL_USERNAME="apikey"
MAIL_PASSWORD=""
MAIL_ENCRYPTION="tls"
EMAIL_FROM="naoresponda@seudominio.com.br"

#Google Tag Manager
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXXX"

# Database (MySQL)
# Formato: mysql://usuario:senha@host:3306/nome_do_banco
# Exemplos de provedores compatíveis com Vercel:
#   PlanetScale (serverless MySQL):  mysql://user:pass@host/db?sslaccept=strict
#   Railway MySQL:                   mysql://root:pass@host:3306/railway
#   Clever Cloud MySQL:              mysql://user:pass@host:3306/db

DB_TYPE="mariadb" # mysql or mariadb
DB_COLLATION="utf8mb4_unicode_ci"
DATABASE_URL="mysql://user:password@host:3306/cbodonto"
SHADOW_DATABASE_URL="mysql://user:password@host:3306/cbodonto"

# NextAuth
NEXTAUTH_SECRET="gere com: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:$PORT"

#S3
AWS_ACCESS_KEY_ID="coloqeu aqui o access key"
AWS_SECRET_ACCESS_KEY="coloque aqui sua chave secreta"
AWS_S3_REGION="us-east-2" # us-east-1 / us-east-2 / ...
AWS_S3_BUCKET="nome-do-bucket"
AWS_S3_FOLDER="pasta de destino"